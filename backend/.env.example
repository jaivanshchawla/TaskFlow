# Server
PORT=8080
ENV=development

# Database
DATABASE_URL=postgresql://taskflow:taskflow_secret@localhost:5432/taskflow_db

# Clerk Authentication
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key_here
CLERK_WEBHOOK_SECRET=whsec_your_webhook_secret_here
